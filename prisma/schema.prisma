generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
  artifacts     Artifact[]
  swarmTasks    SwarmTask[]
  terminalSessions TerminalSession[]
  memories      Memory[]

  @@index([createdAt])
}

model Conversation {
  id          String   @id @default(cuid())
  workspaceId String
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages      Message[]
  brainExecutions BrainExecution[]

  @@index([workspaceId])
  @@index([createdAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system
  content        String
  metadata       String?  // JSON
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  type      String   // planner, architect, researcher, coder, reviewer, verifier, memory
  status    String   @default("idle") // idle, active, error
  config    String?  // JSON
  createdAt DateTime @default(now())

  @@index([type])
  @@index([status])
}

model Memory {
  id          String    @id @default(cuid())
  type        String    // session, workspace, agent, artifact, knowledge
  content     String
  summary     String?
  importance  Float     @default(0.5)
  metadata    String?   // JSON
  workspaceId String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  sourceEdges    MemoryEdge[]  @relation("SourceMemory")
  targetEdges    MemoryEdge[]  @relation("TargetMemory")

  @@index([type])
  @@index([workspaceId])
  @@index([importance])
  @@index([createdAt])
}

model MemoryEdge {
  id             String   @id @default(cuid())
  sourceMemoryId String
  targetMemoryId String
  relationType   String
  weight         Float    @default(1.0)
  createdAt      DateTime @default(now())

  sourceMemory Memory @relation("SourceMemory", fields: [sourceMemoryId], references: [id], onDelete: Cascade)
  targetMemory Memory @relation("TargetMemory", fields: [targetMemoryId], references: [id], onDelete: Cascade)

  @@index([sourceMemoryId])
  @@index([targetMemoryId])
  @@index([relationType])
}

model Artifact {
  id             String   @id @default(cuid())
  name           String
  type           String   // code, markdown, pdf, docx, pptx, image, json, yaml, repo
  content        String
  language       String?
  workspaceId    String
  conversationId String?
  version        Int      @default(1)
  metadata       String?  // JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
  @@index([createdAt])
}

model ModelProvider {
  id        String   @id @default(cuid())
  name      String
  provider  String   // openai, claude, gemini, glm, mistral, qwen, deepseek
  apiKey    String?
  baseUrl   String?
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  config    String?  // JSON
  createdAt DateTime @default(now())

  @@index([provider])
  @@index([enabled])
  @@index([priority])
}

model SwarmTask {
  id          String   @id @default(cuid())
  workspaceId String
  description String
  status      String   @default("pending") // pending, running, completed, failed
  complexity  String   @default("simple")  // simple, medium, complex, enterprise
  agentIds    String?  // JSON array
  result      String?  // JSON
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model BrainExecution {
  id             String   @id @default(cuid())
  conversationId String
  brainOrder     String?  // JSON array of brain IDs
  results        String?  // JSON
  status         String   @default("pending") // pending, running, completed, failed
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
}

model TerminalSession {
  id          String   @id @default(cuid())
  workspaceId String
  cwd         String   @default("/")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Metric {
  id        String   @id @default(cuid())
  type      String
  value     Float
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ─── Enterprise Auth & RBAC Models ─────────────────────────

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  salt         String
  role         String    @default("viewer")
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@index([username])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  result    String
  details   String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([resource])
}

model EncryptedSecret {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // encrypted JSON
  keyId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Permission {
  id        String  @id @default(cuid())
  userId    String
  resource  String
  action    String
  granted   Boolean @default(true)
  grantedBy String?
  createdAt DateTime @default(now())

  @@unique([userId, resource, action])
  @@index([userId])
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String   // JSON array
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}
