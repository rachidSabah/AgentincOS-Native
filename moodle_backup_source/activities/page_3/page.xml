  <content>&lt;div style="background:#f4f4f4; padding:20px; border-radius:10px;"&gt;&lt;h3&gt;Arrival Time Calculator&lt;/h3&gt;&lt;p&gt;Scenario: Depart at 08:00 GMT, Flight Duration 4h.&lt;/p&gt;&lt;input type="text" id="ans" placeholder="Arrival GMT?"&gt;&lt;button onclick="check()"&gt;Check&lt;/button&gt;&lt;p id="fb"&gt;&lt;/p&gt;&lt;/div&gt;&lt;script&gt;function check(){ var a=document.getElementById("ans").value; document.getElementById("fb").innerHTML = (a=="12:00") ? "Correct!" : "Try again!"; }&lt;/script&gt;</content>
